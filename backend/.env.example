# MongoDB connection string
# Local: mongodb://127.0.0.1:27017/littlebeadstudio
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/littlebeadstudio
MONGO_URI=mongodb://127.0.0.1:27017/littlebeadstudio

# Port the API server runs on
PORT=5000

# Email credentials used to send you contact-form notifications.
# If using Gmail: create an "App Password" (not your normal password) at
# https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# The address that should RECEIVE contact form messages (can be the same as above)
CONTACT_EMAIL=your-email@gmail.com

# Where the React frontend runs, for CORS
CLIENT_URL=http://localhost:5173
